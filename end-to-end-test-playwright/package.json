{
  "name": "end-to-end-test-playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "./scripts/with-env.sh playwright test --headed",
    "test:update": "./scripts/with-env.sh playwright test --update-snapshots",
    "test:ui": "./scripts/with-env.sh playwright test --headed --ui",
    "test:docker": "./scripts/docker-test.sh",
    "test:docker:update": "./scripts/docker-test.sh --update-snapshots",
    "test:wsi:nginx": "WSI_PROXY_REHEARSAL=1 WSI_VIEWER_BASE_URL=${WSI_VIEWER_BASE_URL:-http://localhost:3001} playwright test tests/wsi-viewer.spec.ts",
    "test:docker:localdb": "PW_LOCAL=1 CBIOPORTAL_URL=http://localhost:8080 ./scripts/docker-test.sh tests/local",
    "test:docker:localdb:update": "PW_LOCAL=1 CBIOPORTAL_URL=http://localhost:8080 ./scripts/docker-test.sh tests/local --update-snapshots",
    "test:localdb": "PW_LOCAL=1 LOCALDEV=0 CBIOPORTAL_URL=http://localhost:8080 playwright test --headed tests/local",
    "test:localdb:update": "PW_LOCAL=1 LOCALDEV=0 CBIOPORTAL_URL=http://localhost:8080 playwright test tests/local --update-snapshots",
    "test:localdb:ui": "PW_LOCAL=1 LOCALDEV=0 CBIOPORTAL_URL=http://localhost:8080 playwright test --headed --ui tests/local",
    "report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^6.0.3"
  }
}
