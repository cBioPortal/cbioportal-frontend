# cBioPortal E2E Test Runner
#
# Contains Chrome, WebDriverIO, and all test specs (local + remote).
# Point it at a running cBioPortal instance to run tests.
#
# Build (from cbioportal-frontend root):
#   docker build -f end-to-end-test/Dockerfile.e2e-runner -t cbioportal/e2e-runner:latest .
#
# Run local tests (against a local backend + frontend):
#   docker run --network host \
#     -e CBIOPORTAL_URL=http://localhost \
#     -e SPEC_FILE_PATTERN="./local/specs/**/*.spec.js" \
#     cbioportal/e2e-runner:latest
#
# Run remote tests (against production or staging):
#   docker run --network host \
#     -e CBIOPORTAL_URL=https://www.cbioportal.org \
#     -e SPEC_FILE_PATTERN="./remote/specs/**/*.spec.js" \
#     cbioportal/e2e-runner:latest
#
# Run a single test:
#   docker run --network host \
#     -e CBIOPORTAL_URL=http://localhost \
#     -e SPEC_FILE_PATTERN="./local/specs/core/patientview.spec.js" \
#     cbioportal/e2e-runner:latest
#
# Save results to host:
#   docker run --network host \
#     -v ./results:/tests/local/junit \
#     -e CBIOPORTAL_URL=http://localhost \
#     cbioportal/e2e-runner:latest

FROM node:22.18.0

# Install dependencies for Chrome and utilities
RUN apt-get update -qq && \
    apt-get install -y -qq wget unzip fonts-liberation libasound2 \
    libatk-bridge2.0-0 libatk1.0-0 libcups2 libdbus-1-3 libdrm2 \
    libgbm1 libgtk-3-0 libnspr4 libnss3 libxcomposite1 libxdamage1 \
    libxrandr2 xdg-utils > /dev/null 2>&1 && \
    rm -rf /var/lib/apt/lists/*

# Install Chrome
ARG CHROME_VERSION=139.0.7258.154
RUN wget -q "https://dl.google.com/linux/chrome/deb/pool/main/g/google-chrome-stable/google-chrome-stable_${CHROME_VERSION}-1_amd64.deb" && \
    dpkg -i "google-chrome-stable_${CHROME_VERSION}-1_amd64.deb" || apt-get install -yf && \
    rm "google-chrome-stable_${CHROME_VERSION}-1_amd64.deb"

# Install ChromeDriver
RUN wget -q "https://storage.googleapis.com/chrome-for-testing-public/${CHROME_VERSION}/linux64/chromedriver-linux64.zip" && \
    unzip -q chromedriver-linux64.zip && \
    mv chromedriver-linux64/chromedriver /usr/local/bin/ && \
    chmod +x /usr/local/bin/chromedriver && \
    rm -rf chromedriver-linux64.zip chromedriver-linux64

# Install test dependencies
WORKDIR /tests
COPY end-to-end-test/package.json end-to-end-test/yarn.lock ./
RUN corepack enable && yarn install --frozen-lockfile

# Copy all test specs (local + remote) and shared utilities
COPY end-to-end-test/local/ ./local/
COPY end-to-end-test/remote/ ./remote/
COPY end-to-end-test/shared/ ./shared/

ENV CHROMEDRIVER_CUSTOM_PATH=/usr/local/bin/chromedriver
ENV HEADLESS_CHROME=true
ENV FRONTEND_TEST_USE_LOCAL_DIST=true

# Defaults - override via env vars
ENV CBIOPORTAL_URL=http://localhost
ENV SPEC_FILE_PATTERN=./local/specs/**/*.spec.js
ENV SCREENSHOT_DIRECTORY=./local/screenshots
ENV JUNIT_REPORT_PATH=./local/junit/

ENTRYPOINT ["npx", "wdio", "./shared/wdio/wdio.conf.js"]
