<!DOCTYPE html>
<html class="cbioportal-frontend" lang="en">
<head>
    <meta http-equiv="Content-type" content="text/html; charset=utf-8"/>
    <link rel="icon" href="/images/cbioportal_icon.png"/>
    <title>cBioPortal for Cancer Genomics</title>
    <script>

        window.devContext = true;
        window.frontendConfig = {
        }

        // rawServerConfig for development
        // this would normally come from the backend JSP template
        // msk_wsi_tile_server_url uses window.location.origin so that tile
        // requests go through the dev server's proxy (rspack proxies /patient/P-*
        // and /tiles/* to the local tile server at :8081)
        //
        // app_name 'localdbe2e' bypasses the session service check in Container.tsx
        // (which would show an error screen), while sessionServiceEnabled:false
        // prevents the frontend from calling session service endpoints that return
        // 500/405 (because session.service.url is not configured in portal.properties)
        window.rawServerConfig = {
            app_name: 'localdbe2e',
            msk_wsi_tile_server_url: window.location.origin,
            sessionServiceEnabled: false,
            authenticationMethod: 'noauth',
            user_display_name: 'anonymousUser',
        }

        /* REMOVED: This is an example of how to add custom tabs to the patient page. Enabling this will clobber localStorage.frontendConfig that is set through the browser console
        localStorage.frontendConfig = JSON.stringify(
        {
            serverConfig:{

                custom_tabs:[
                    {
                        title: 'Sync Tab',
                        id: 'customTab1',
                        location: 'PATIENT_PAGE',
                        mountCallback: `(div)=>{
                                $(div).html("tab for patient " + window.location.search.split("=").slice(-1))
                            }`,
                    },
                    {
                        title: 'Async Tab',
                        id: 'customTab2',
                        location: 'PATIENT_PAGE',
                        hideAsync: `()=>{
                                    return new Promise((resolve)=>{
                                            setTimeout(()=>{
                                                resolve(true);
                                            }, 2000);
                                    });
                                }`,
                    },
                ]
            }
        });
        */

    function renderCustomTab1(div, tab){
        $(div).append(`<div>this is the content for <strong>${tab.title}</strong></div>`);
    }


    </script>

    <link href="/reactapp/prefixed-bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" rel="stylesheet" />
</head>
<body>

<div id="reactRoot"></div>

</body>
</html>
