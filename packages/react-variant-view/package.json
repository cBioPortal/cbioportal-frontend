{
  "name": "react-variant-view",
  "version": "0.4.3",
  "description": "cBioPortal Variant Viewer",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "jsnext:main": "dist/index.es.js",
  "typings": "dist/index.d.ts",
  "styles": "dist/styles.css",
  "engines": {
    "node": "22.18.0"
  },
  "files": [
    "dist"
  ],
  "author": "cBioPortal",
  "license": "AGPL-3.0-or-later",
  "repository": "cBioPortal/cbioportal-frontend",
  "scripts": {
    "build": "pnpm run tcm && cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=2048 pnpm run rollup",
    "start": "pnpm run watch",
    "watch": "concurrently \"pnpm run tcm:watch\" \"pnpm run rollup:watch\"",
    "watchSSL": "pnpm run watch",
    "rollup": "rollup -c rollup.config.ts",
    "rollup:watch": "pnpm run rollup --watch",
    "tcm": "tcm -p src/**/*.module.scss",
    "tcm:watch": "pnpm run tcm --watch",
    "prepare": "pnpm run build",
    "test": "cross-env jest $GREP --env=jsdom --runInBand --ci --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:watch": "pnpm run test --watch"
  },
  "peerDependencies": {
    "bootstrap": "^3.0.0 || ^4.0.0",
    "mobx": "^6.0.0",
    "mobx-react": "^6.0.0",
    "react": "^15.0.0 || ^16.0.0",
    "react-dom": "^15.0.0 || ^16.0.0"
  },
  "dependencies": {
    "autobind-decorator": "^2.1.0",
    "cbioportal-frontend-commons": "workspace:*",
    "cbioportal-utils": "workspace:*",
    "classnames": "^2.2.5",
    "font-awesome": "^4.7.0",
    "genome-nexus-ts-api-client": "workspace:*",
    "jquery": "^3.2.1",
    "lodash": "^4.17.21",
    "oncokb-styles": "~1.4.2",
    "oncokb-ts-api-client": "workspace:*",
    "react-bootstrap": "^0.31.5",
    "react-collapse": "4.0.3",
    "react-if": "^2.1.0",
    "react-motion": "^0.5.2",
    "react-mutation-mapper": "workspace:*",
    "react-rangeslider": "^2.2.0",
    "react-select": "^3.0.4",
    "react-table": "^6.10.0",
    "seamless-immutable": "^7.1.4",
    "superagent": "^3.8.3",
    "typescript": "4.0.3"
  }
}
