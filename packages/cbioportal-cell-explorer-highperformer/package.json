{
  "name": "cbioportal-cell-explorer-highperformer",
  "description": "High-performance cell viewer (deck.gl scatterplot + charts) from cBioPortal cell-explorer",
  "version": "0.1.0",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "jsnext:main": "dist/index.es.js",
  "typings": "dist/index.d.ts",
  "styles": "dist/styles.css",
  "engines": {
    "node": "22.18.0"
  },
  "files": [
    "dist"
  ],
  "author": "cBioPortal",
  "license": "AGPL-3.0-or-later",
  "repository": "cBioPortal/cbioportal-frontend",
  "scripts": {
    "build": "cross-env NODE_ENV=production NODE_OPTIONS=--max-old-space-size=2048 pnpm run rollup",
    "start": "pnpm run watch",
    "watch": "pnpm run rollup:watch",
    "watchSSL": "pnpm run watch",
    "rollup": "rollup -c rollup.config.ts",
    "rollup:watch": "rollup -c rollup.config.ts -w",
    "prepare": "pnpm run build",
    "test": "cross-env jest $GREP --env=jsdom --runInBand --ci --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:watch": "pnpm run test --watch"
  },
  "peerDependencies": {
    "@ant-design/icons": "^4.0.0",
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/extensions": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@deck.gl/react": "^9.0.0",
    "@visx/axis": "^3.0.0",
    "@visx/group": "^3.0.0",
    "@visx/scale": "^3.0.0",
    "@visx/shape": "^3.0.0",
    "@visx/zoom": "^3.0.0",
    "antd": "^4.0.0",
    "cbioportal-cell-explorer-profiler": "workspace:*",
    "cbioportal-cell-explorer-zarrstore": "workspace:*",
    "react": "^16.8.0 || ^17.0.0",
    "react-dom": "^16.8.0 || ^17.0.0",
    "react-router-dom": "^5.0.0",
    "zustand": "^4.0.0"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.9",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "rc-virtual-list": "^3.5.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@ant-design/icons": "^4.8.3",
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/extensions": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@deck.gl/react": "^9.0.0",
    "@types/react": "^16.14.0",
    "@types/react-dom": "^16.9.0",
    "@types/react-router-dom": "^5.3.0",
    "@visx/axis": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/zoom": "^3.12.0",
    "antd": "^4.24.16",
    "react-router-dom": "^5.3.4",
    "zustand": "^4.5.0"
  }
}
